#################################################################
#    fine metadati 
#################################################################


#################################################################
#    Datatypes

#################################################################

###  http://www.w3.org/2001/XMLSchema#boolean
xsd:boolean rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#string
xsd:string rdf:type rdfs:Datatype .


#################################################################
#    Object Properties

#################################################################


###  https://w3id.org/italia/onto/CLV/hasSpatialCoverage
CLV:hasSpatialCoverage rdf:type owl:ObjectProperty .


###  https://w3id.org/italia/real-estate/onto/StateProperty/haCategoriaBene
StateProperty:haCategoriaBene rdf:type owl:ObjectProperty ,
                                       owl:FunctionalProperty ;
                              rdfs:domain StateProperty:SchedaCatalogazioneBene ;
                              rdfs:range StateProperty:CategoriaBeneImmobile ;
                              rdfs:label "ha categoria bene dello Stato"@it ,
                                         "has category State Property"@en .


###  https://w3id.org/italia/real-estate/onto/StateProperty/haCategoriaPatrimoniale
StateProperty:haCategoriaPatrimoniale rdf:type owl:ObjectProperty ,
                                               owl:FunctionalProperty ;
                                      rdfs:domain StateProperty:StatoBeneImmobile ;
                                      rdfs:range StateProperty:TipoCategoriaPatrimonialeImmobile ;
                                      rdfs:label "ha categoria patrimoniale"@it ,
                                                 "has asset category"@en .


###  https://w3id.org/italia/real-estate/onto/StateProperty/haCodiceSEC
StateProperty:haCodiceSEC rdf:type owl:ObjectProperty ,
                                   owl:FunctionalProperty ;
                          rdfs:domain StateProperty:BeneImmobileDelloStato ;
                          rdfs:range StateProperty:CodiceMEFRaccordoSECBeneImmobile ;
                          rdfs:label "ha codice SEC"@it ,
                                     "has ESA code"@en .


###  https://w3id.org/italia/real-estate/onto/StateProperty/haDestinazioneUso
StateProperty:haDestinazioneUso rdf:type owl:ObjectProperty ,
                                         owl:FunctionalProperty ;
                                rdfs:domain StateProperty:StatoBeneImmobile ;
                                rdfs:range StateProperty:TipoDestinazioneUsoImmobile ;
                                rdfs:label "ha destinazione di uso"@it ,
                                           "has designed use"@en .


###  https://w3id.org/italia/real-estate/onto/StateProperty/haSchedaCatalogazione
StateProperty:haSchedaCatalogazione rdf:type owl:ObjectProperty ;
                                    rdfs:domain StateProperty:BeneImmobileDelloStato ;
                                    rdfs:range StateProperty:SchedaCatalogazioneBene ;
                                    rdfs:label "ha scheda di catalogazione"@it ,
                                               "has a catalog record"@en .


###  https://w3id.org/italia/real-estate/onto/StateProperty/haStatoAgibilità
StateProperty:haStatoAgibilità rdf:type owl:ObjectProperty ,
                                        owl:FunctionalProperty ;
                               rdfs:domain StateProperty:StatoBeneImmobile ;
                               rdfs:range StateProperty:TipoStatoAgibilitàImmobile ;
                               rdfs:label "ha stato di agibilità"@it ,
                                          "has status of habitability"@en .


###  https://w3id.org/italia/real-estate/onto/StateProperty/haStatoDelBeneImmobile
StateProperty:haStatoDelBeneImmobile rdf:type owl:ObjectProperty ,
                                              owl:InverseFunctionalProperty ;
                                     rdfs:domain StateProperty:BeneImmobileDelloStato ;
                                     rdfs:range StateProperty:StatoBeneImmobile ;
                                     rdfs:label "ha stato del bene immobile dello Stato"@it ,
                                                "has status the property real-estate"@en .


###  https://w3id.org/italia/real-estate/onto/StateProperty/haStatoOccupazione
StateProperty:haStatoOccupazione rdf:type owl:ObjectProperty ,
                                          owl:FunctionalProperty ;
                                 rdfs:domain StateProperty:StatoBeneImmobile ;
                                 rdfs:range StateProperty:TipoStatoOccupazioneImmobile ;
                                 rdfs:label "ha stato di occupazione"@it ,
                                            "has occupation status"@en .


###  https://w3id.org/italia/real-estate/onto/StateProperty/haTipoAccesso
StateProperty:haTipoAccesso rdf:type owl:ObjectProperty ,
                                     owl:FunctionalProperty ;
                            rdfs:domain StateProperty:StatoBeneImmobile ;
                            rdfs:range StateProperty:TipoAccessoImmobile ;
                            rdfs:label "ha tipo di accesso"@it ,
                                       "has access type"@en .


###  https://w3id.org/italia/real-estate/onto/StateProperty/riferisceProvincia
StateProperty:riferisceProvincia rdf:type owl:ObjectProperty ,
                                          owl:FunctionalProperty ;
                                 rdfs:domain StateProperty:SchedaCatalogazioneBene ;
                                 rdfs:range CLV:Province ;
                                 rdfs:label "related to province"@en ,
                                            "riferisce provincia"@it .


#################################################################
#    Data properties

#################################################################


###  https://w3id.org/italia/real-estate/onto/StateProperty/avvisoSchedaProvvisoria
StateProperty:avvisoSchedaProvvisoria rdf:type owl:DatatypeProperty ,
                                               owl:FunctionalProperty ;
                                      rdfs:domain StateProperty:SchedaCatalogazioneBene ;
                                      rdfs:range xsd:boolean ;
                                      rdfs:label "avviso scheda provvisoria"@it ,
                                                 "provisional record notice"@en .


###  https://w3id.org/italia/real-estate/onto/StateProperty/codiceSchedaCatalogazione
StateProperty:codiceSchedaCatalogazione rdf:type owl:DatatypeProperty ,
                                                 owl:FunctionalProperty ;
                                        rdfs:domain StateProperty:SchedaCatalogazioneBene ;
                                        rdfs:range xsd:string ;
                                        rdfs:label "cataloguing record code"@en ,
                                                   "codice scheda catalogazione"@it .


#################################################################
#    Classes

#################################################################


###  https://w3id.org/italia/onto/CLV/Identifier
CLV:Identifier rdf:type owl:Class .


###  https://w3id.org/italia/onto/CLV/Province
CLV:Province rdf:type owl:Class .


###  https://w3id.org/italia/onto/TI/TimeIndexedEvent
TI:TimeIndexedEvent rdf:type owl:Class .


###  https://w3id.org/italia/real-estate/onto/StateProperty/BeneImmobileDelloStato
StateProperty:BeneImmobileDelloStato rdf:type owl:Class ;
                                     rdfs:subClassOf StateProperty:Cespite ,
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty CLV:hasSpatialCoverage ;
                                                       owl:someValuesFrom owl:Thing
                                                     ] ;
                                     rdfs:comment """Bene immobile (812 c.c.), appartenente allo Stato, assoggettato ai regimi giuridici previsti dal Codice Civile e dalle leggi speciali vigenti.
I beni immobili dello Stato, in gestione all’Agenzia del Demanio, si classificano in:
• Beni patrimoniali immobili indisponibili: beni immobili appartenenti allo Stato non rientranti nella categoria dei beni demaniali (art. 826 ss.c.c.).
• Beni immobili patrimoniali disponibili: tutti i beni immobili di proprietà dello Stato diversi dai beni demaniali e patrimoniali indisponibili (art. 828 c.c.).
Per quanto concerne i beni demaniali (art. 822 c.c.), la gestione dell’Agenzia del Demanio è riferita unicamente a quelli d'interesse storico / artistico non già in gestione al Ministero per i Beni Culturali."""@it ,
                                                  """Real estate (Article 812 of the Italian Civil Code) belonging to the State, subject to the legal regimes established by the Civil Code and applicable special laws.
State-owned real estate, managed by the State Property Agency, is classified as follows:
• Unavailable immovable assets: real estate belonging to the State that does not fall within the category of state-owned property (Article 826 et seq. of the Italian Civil Code).
• Available immovable assets: all real estate owned by the State other than state-owned property and unavailable patrimonial property (Article 828 of the Italian Civil Code).
With regard to state-owned property (Article 822 of the Italian Civil Code), the management of the State Property Agency refers solely to those of historical/artistic interest not already managed by the Ministry of Cultural Heritage."""@en ;
                                     rdfs:label "Bene immobile dello Stato"@it ,
                                                "State Real Estate Asset"@en .


###  https://w3id.org/italia/real-estate/onto/StateProperty/CategoriaBeneImmobile
StateProperty:CategoriaBeneImmobile rdf:type owl:Class ;
                                    rdfs:comment """Tipologia di beni immobili dello Stato gestiti dall’Agenzia del Demanio:
- Beni Patrimoniali
- Demanio Artistico-Storico non in gestione al Ministero per i beni culturali
- Beni non di proprietà dello stato su cui lo Stato vanta diritti reali."""@it ,
                                                 """Types of State-owned real estate assets managed by the State Property Agency:
- Heritage Assets
- Artistic-Historical State Property not managed by the Ministry of Cultural Heritage
- Non-state-owned assets over which the State holds real rights."""@en ;
                                    rdfs:label "Categoria di bene immobile dello Stato"@it ,
                                               "State Real Estate Asset Category"@en .


###  https://w3id.org/italia/real-estate/onto/StateProperty/Cespite
StateProperty:Cespite rdf:type owl:Class ;
                      rdfs:comment "A tangible or intangible item of a durable nature, monetizable and subject to depreciation"@en ,
                                   "Bene materiale/immateriale di natura durevole nel tempo, monetizzabile e ammortizzabile."@it ;
                      rdfs:label "Asset"@en ,
                                 "Cespite"@it .


###  https://w3id.org/italia/real-estate/onto/StateProperty/CodiceMEFRaccordoSEC
StateProperty:CodiceMEFRaccordoSEC rdf:type owl:Class ;
                                   rdfs:subClassOf CLV:Identifier ;
                                   rdfs:comment "Asset classification adopted by the Ministry of Economy and Finance (MEF) to align with the classification of assets and liabilities defined in the European System of Accounts (ESA ’95)."@en ,
                                                "Classificazione patrimoniale adottata dal MEF per conformarsi alla classificazione delle poste attive e passive riportate nel SEC ’95 (Reg. (CE) 2223/96; Decreto Interministeriale 18 Aprile 2002; Circolare MEF – Ragioneria Generale dello Stato n. 13 del 3 aprile 2003; D. Lgs. 279/1997)."@it ;
                                   rdfs:label "Codice MEF di raccordo SEC"@it ,
                                              "MEF Bridging Code for ESA"@en .


###  https://w3id.org/italia/real-estate/onto/StateProperty/CodiceMEFRaccordoSECBeneImmobile
StateProperty:CodiceMEFRaccordoSECBeneImmobile rdf:type owl:Class ;
                                               rdfs:subClassOf StateProperty:CodiceMEFRaccordoSEC ;
                                               rdfs:comment "Asset classification of real estate adopted by the Ministry of the Economy and Finance to comply with the classification of assets and liabilities reported in the ESA '95 (Reg. (EC) 2223/96; Interministerial Decree 18 April 2002; MEF – State General Accounting Office Circular no. 13 of 3 April 2003; Legislative Decree 279/1997)."@en ,
                                                            "Classificazione patrimoniale dei beni immobili adottata dal MEF per conformarsi alla classificazione delle poste attive e passive riportate nel SEC ’95 (Reg. (CE) 2223/96; Decreto Interministeriale 18 Aprile 2002; Circolare MEF – Ragioneria Generale dello Stato n. 13 del 3 aprile 2003; D. Lgs. 279/1997)."@it ;
                                               rdfs:label "Codice MEF di raccordo SEC per bene immobile"@it ,
                                                          "MEF Bridging Code for ESA - real estate"@en .


###  https://w3id.org/italia/real-estate/onto/StateProperty/Fabbricato
StateProperty:Fabbricato rdf:type owl:Class ;
                         owl:disjointWith StateProperty:Terreno ;
                         rdfs:comment "Bene immobile inteso come qualsiasi costruzione coperta, isolata da vie o da spazi vuoti, oppure separata da altre costruzioni medianti muri che si elevano, senza soluzione di continuità, dalle fondamenta al tetto, che disponga di uno o più liberi accessi sulla via, e possa avere una o più scale autonome (art. 812 c.c)."@it ,
                                      "Real estate is understood as any covered building, isolated from streets or empty spaces, or separated from other buildings by walls that rise seamlessly from the foundations to the roof, which has one or more free accesses from the street, and can have one or more independent staircases (art. 812 of the Civil Code)."@en ;
                         rdfs:label "Building"@en ,
                                    "Fabbricato"@it .


###  https://w3id.org/italia/real-estate/onto/StateProperty/SchedaCatalogazioneBene
StateProperty:SchedaCatalogazioneBene rdf:type owl:Class ;
                                      owl:equivalentClass [ rdf:type owl:Restriction ;
                                                            owl:onProperty StateProperty:haCategoriaBene ;
                                                            owl:someValuesFrom owl:Thing
                                                          ] ,
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty StateProperty:riferisceProvincia ;
                                                            owl:someValuesFrom owl:Thing
                                                          ] ;
                                      rdfs:comment """La scheda rappresenta l’unità base di catalogazione e può contenere uno o più beni immobili, qualora questi risultino:
•  Fisicamente contigui (ad esempio, più edifici all’interno di un medesimo compendio);
•  Funzionalmente integrati (ad esempio, strutture che operano congiuntamente per finalità istituzionali o operative);
•  Gestiti unitariamente ai fini amministrativi, contabili o patrimoniali."""@it ,
                                                   """The record represents the basic cataloging unit and may contain one or more real estate properties, provided they are:
• Physically contiguous (for example, multiple buildings within the same complex);
• Functionally integrated (for example, structures that operate jointly for institutional or operational purposes);
• Managed jointly for administrative, accounting, or asset management purposes."""@en ;
                                      rdfs:label "Scheda di catalogazione del bene dello Stato"@it ,
                                                 "State Asset Cataloguing Record"@en .


###  https://w3id.org/italia/real-estate/onto/StateProperty/StatoBeneImmobile
StateProperty:StatoBeneImmobile rdf:type owl:Class ;
                                owl:equivalentClass [ rdf:type owl:Restriction ;
                                                      owl:onProperty [ owl:inverseOf StateProperty:haStatoDelBeneImmobile
                                                                     ] ;
                                                      owl:someValuesFrom owl:Thing
                                                    ] ;
                                rdfs:subClassOf TI:TimeIndexedEvent ;
                                rdfs:comment "Condizione giuridica, amministrativa o funzionale in cui si trova un bene immobile dello Stato in un determinato momento. Essa è descritta attraverso specifiche tipologie di stato che caratterizzano il bene ai fini della gestione patrimoniale, tra cui: tipo categoria patrimoniale, destinazione d’uso, tipologia di accesso, stato di agibilità e stato di occupazione dell’immobile."@it ,
                                             "Legal, administrative, or functional condition of a state-owned real estate asset at a given time. It is described through specific status types that characterize the asset for asset management purposes, including: asset category, intended use, type of access, usability status, and occupancy status of the property."@en ;
                                rdfs:label "Stato del Bene immobile dello Stato"@it ,
                                           "Status of State Real Estate"@en .


###  https://w3id.org/italia/real-estate/onto/StateProperty/Terreno
StateProperty:Terreno rdf:type owl:Class ;
                      rdfs:comment "Bene immobile inteso come porzione di suolo priva di edificazioni (art. 812 c.c.) cui viene assegnata una particolare destinazione d’uso sulla base delle norme e degli strumenti urbanistici vigenti."@it ,
                                   "Real estate defined as a portion of land free of buildings (Article 812 of the Italian Civil Code) assigned a specific use based on current urban planning regulations and instruments."@en ;
                      rdfs:label "Land"@en ,
                                 "Terreno"@it .


###  https://w3id.org/italia/real-estate/onto/StateProperty/TipoAccessoImmobile
StateProperty:TipoAccessoImmobile rdf:type owl:Class ;
                                  rdfs:comment "La tipologia di accesso di un cespite immobiliare rappresenta la modalità fisica e funzionale attraverso cui è possibile accedere all’unità immobiliare o all’area. Essa descrive le caratteristiche dell’accessibilità in relazione alla destinazione d’uso, alla configurazione dell’immobile e alla sua fruibilità da parte di utenti, enti o soggetti terzi."@it ,
                                               "The access type of a real estate asset represents the physical and functional means by which the property or area can be accessed. It describes the accessibility characteristics in relation to the intended use, the property's configuration, and its usability by users, entities, or third parties."@en ;
                                  rdfs:label "Tipo di accesso a immobile dello Stato"@it ,
                                             "Type of State Real Estate Access"@en .


###  https://w3id.org/italia/real-estate/onto/StateProperty/TipoCategoriaPatrimonialeImmobile
StateProperty:TipoCategoriaPatrimonialeImmobile rdf:type owl:Class ;
                                                rdfs:comment """Tipologia di beni immobili dello Stato gestiti dall’Agenzia del Demanio:
• beni disponibili
• beni assegnati in uso governativo
• beni indisponibili
• beni su cui gravano dir. reali a favore terzi
• diritti reali su beni patrimoniali
• dir. reali su beni di proprietà di comuni
• dir. reali su beni di proprietà di provincie
• dir. reali su beni di proprietà di regioni
• beni di demanio culturale non in gestione al Ministero per i beni culturali"""@it ,
                                                             """Types of State-owned real estate managed by the State Property Agency:
• available assets
• assets assigned for government use
• unavailable assets
• assets subject to third-party real estate rights
• real estate rights on assets
• real estate rights on assets owned by municipalities
• real estate rights on assets owned by provinces
• real estate rights on assets owned by regions
• cultural state-owned assets not managed by the Ministry of Cultural Heritage"""@en ;
                                                rdfs:label "Tipo di categoria patrimoniale immobile dello Stato"@it ,
                                                           "Type of State Real Estate Asset Category"@en .


###  https://w3id.org/italia/real-estate/onto/StateProperty/TipoDestinazioneUsoImmobile
StateProperty:TipoDestinazioneUsoImmobile rdf:type owl:Class ;
                                          rdfs:comment "Classification of state-owned buildings based on their intended use, in accordance with current legislation and urban planning tools (Article 23-ter of Presidential Decree No. 380 of June 6, 2001 - Consolidated Building Act; Legislative Decree No. 652 of April 13, 1939; Presidential Decree No. 1142 of December 1949; Legislative Decree No. 200 of December 22, 2008, converted with amendments by Law No. 9 of February 18, 2009)."@en ,
                                                       "Classificazione degli immobili dello Stato in base alla loro destinazione d’uso, coerentemente con la normativa e gli strumenti urbanistici vigenti (art. 23 ter D.P.R. 6 giugno 2001, n. 380 - Testo Unico Edilizia; d.l. 13 aprile 1939, n. 652; D.P.R. dicembre 1949, n. 1142; d.l. 22 dicembre 2008, n. 200, convertito con modificazioni dalla l. 18 febbraio 2009, n. 9)."@it ;
                                          rdfs:label "Tipo di destinazione di uso degli immobili dello Stato"@it ,
                                                     "Type of designation for State Real Estates"@en .


###  https://w3id.org/italia/real-estate/onto/StateProperty/TipoStatoAgibilitàImmobile
StateProperty:TipoStatoAgibilitàImmobile rdf:type owl:Class ;
                                         rdfs:comment "Existence of safety, hygiene, health, and energy-saving conditions for buildings and their installations, and, where applicable, compliance with digital infrastructure requirements assessed in accordance with current legislation (Article 24 of Presidential Decree 380/2001)."@en ,
                                                      "Sussistenza delle condizioni di sicurezza, igiene, salubrità, risparmio energetico degli edifici e degli impianti negli stessi installati, e, ove previsto, di rispetto degli obblighi di infrastrutturazione digitale valutate secondo quanto dispone la normativa vigente (art. 24 DPR 380/2001)."@it ;
                                         rdfs:label "Tipo di stato di agibilità immobile dello Stato"@it ,
                                                    "Type of State Real Estate Habitability Status"@en .


###  https://w3id.org/italia/real-estate/onto/StateProperty/TipoStatoOccupazioneImmobile
StateProperty:TipoStatoOccupazioneImmobile rdf:type owl:Class ;
                                           rdfs:comment "Indica la disponibilità giuridica e/o fisica degli immobili dello Stato da parte di soggetti pubblici o privati, secondo le norme del Codice civile e altre leggi speciali vigenti."@it ,
                                                        "Indicates the legal and/or physical availability of state-owned properties by public or private entities, in accordance with the provisions of the Civil Code and other applicable special laws."@en ;
                                           rdfs:label "Tipo di stato di occupazione di immobile dello Stato"@it ,
                                                      "Type of State Real Estate Occupancy Status"@en .


#################################################################
