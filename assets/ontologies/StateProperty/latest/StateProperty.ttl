#################################################################
#    inizio metadati 
#################################################################

<https://w3id.org/italia/real-estate/onto/StateProperty> rdf:type owl:Ontology ;
                                    owl:versionIRI <urn:absolute:0.1> ;
                                    owl:imports <https://w3id.org/italia/onto/l0> , <https://w3id.org/italia/onto/CLV/> ;
                                    dct:accrualPeriodicity <http://publications.europa.eu/resource/authority/frequency/IRREG> ;
                                    dct:creator <https://w3id.org/italia/data/public-organization/ISTAT> ,
												<https://w3id.org/italia/data/public-organization/agd>  ;
                                    dct:description "La risorsa modella il dominio dei beni immobili dello stato gestiti dall’Agenzia del Demanio, definendone le caratteristiche fisiche, le categorie patrimoniali e le specifiche destinazioni d'uso. L'ontologia permette di rappresentare i dati amministrativi e tecnici necessari alla gestione e al monitoraggio del patrimonio immobiliare dello Stato, facilitando l'interoperabilità tra i sistemi informativi dell'Agenzia del Demanio e delle altre pubbliche amministrazioni."@it ,
                                                    "The resource models the domain of state-owned real estate assets managed by the Italian State Property Agency, defining their physical characteristics, property categories, and specific uses. The ontology enables the representation of the administrative and technical data required for the management and monitoring of the State’s real estate assets, facilitating interoperability between the information systems of the State Property Agency and those of other public administrations."@en ;
                                    dct:identifier "https://w3id.org/italia/real-estate/onto/StateProperty" ;
                                    dct:issued "2026-03-16"^^xsd:date ;
                                    dct:language <http://publications.europa.eu/resource/authority/language/ITA> ;
                                    dct:modified "2026-03-16"^^xsd:date ;
                                    dct:publisher <https://w3id.org/italia/data/public-organization/agd> ;
                                    dct:rightsHolder <https://w3id.org/italia/data/public-organization/agd> ; 
                                    dct:title "Ontologia dei beni immobili dello Stato"@it ,
									          "State-Owned Real Estate Assets Ontology"@en ;
									dct:conformsTo <https://w3id.org/italia/data/standard/SKOS> ;
									dct:temporal "Dal 2026" ;
									dct:subject <http://publications.europa.eu/resource/authority/data-theme/ECON> ;
                                    rdfs:comment "Modello concettuale per la rappresentazione dei dati relativi ai beni immobili dello Stato gestiti dall’Agenzia del Demanio, inclusi gli aspetti di catalogazione e agibilità."@it ,
                                                 "Conceptual model for the representation of data related to state-owned real estate assets managed by the Italian State Property Agency, including aspects of cataloguing and usability certification."@en ;
                                    rdfs:isDefinedBy <https://w3id.org/italia/real-estate/onto/StateProperty>  ;
                                    rdfs:label "Ontologia dei beni immobili dello Stato"@it ,
									           "State-Owned Real Estate Assets Ontology"@en ;
                                    owl:versionInfo "Versione 1.0"@en ,
                                                    "Version 1.0"@it ;
                                    dcat:contactPoint <https://w3id.org/italia/data/contact-point/ISTAT-NDC> ;
                                    dcat:keyword "Demanio"@it , "Patrimonio immobiliare dello Stato"@it , "Gestione patrimoniale"@it , "Beni immobili dello Stato"@it ,
                                                 "State property"@en , "Real estate"@en , "Asset management"@en , "State-owned real estate assets"@en ;
                                    dcat:theme <http://publications.europa.eu/resource/authority/data-theme/ECON> ;						
                                    prov:wasDerivedFrom <https://w3id.org/italia/real-estate/onto/StateProperty/1.0> ;
                                    admsapit:acronym "BIS" ;
                                    admsapit:hasContributor <https://w3id.org/italia/data/organization/public-organization/td> ;                               
                                    admsapit:hasOntologyLanguage admsapit:OWL ;
                                    admsapit:hasSemanticAssetDistribution <https://w3id.org/italia/data/distribution/StateProperty-JSON-LD> ,
                                                                          <https://w3id.org/italia/data/distribution/StateProperty-RDF-TURTLE> ,
                                                                          <https://w3id.org/italia/data/distribution/StateProperty-RDF-XML> ;
									admsapit:semanticAssetInUse <https://w3id.org/italia/data/project/CLV> ;
									admsapit:hasKeyClass StateProperty:BeneImmobileDelloStato ;
                                    admsapit:hasTask admsapit:AnnotationTask ,
                                                     admsapit:QueryFormulationTask ,
                                                     admsapit:SearchTask ;
                                    admsapit:officialURI "https://w3id.org/italia/real-estate/onto/StateProperty"^^xsd:anyURI ;
                                    admsapit:prefix "StateProperty" ;
                                    admsapit:status "catalogued" ,
                                                    "published" ;
                                    admsapit:target "Pubbliche Amministrazioni".


