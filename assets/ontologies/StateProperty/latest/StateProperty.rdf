    <owl:Ontology rdf:about="https://w3id.org/italia/onto/l0">
        <owl:versionIRI rdf:resource="urn:absolute:0.1"/>
        <owl:imports rdf:resource="https://w3id.org/italia/onto/CLV/"/>
        <owl:imports rdf:resource="https://w3id.org/italia/onto/l0"/>
        <dcat:keyword xml:lang="it">Patrimonio immobiliare dello Stato</dcat:keyword>
        <dct:title xml:lang="en">State-Owned Real Estate Assets Ontology</dct:title>
        <admsapit:hasTask rdf:resource="https://w3id.org/italia/onto/ADMS/AnnotationTask"/>
        <admsapit:hasTask rdf:resource="https://w3id.org/italia/onto/ADMS/QueryFormulationTask"/>
        <dcat:keyword xml:lang="it">Gestione patrimoniale</dcat:keyword>
        <dcat:keyword xml:lang="en">Asset management</dcat:keyword>
        <dcat:keyword xml:lang="en">State-owned real estate assets</dcat:keyword>
        <admsapit:hasTask rdf:resource="https://w3id.org/italia/onto/ADMS/SearchTask"/>
        <dcat:keyword xml:lang="en">State property</dcat:keyword>
        <dct:conformsTo rdf:resource="https://w3id.org/italia/data/standard/SKOS"/>
        <rdfs:comment xml:lang="it">Modello concettuale per la rappresentazione dei dati relativi ai beni immobili dello Stato gestiti dall’Agenzia del Demanio, inclusi gli aspetti di catalogazione e agibilità.</rdfs:comment>
        <admsapit:target>Pubbliche Amministrazioni</admsapit:target>
        <dct:temporal>Dal 2026</dct:temporal>
        <admsapit:hasOntologyLanguage rdf:resource="https://w3id.org/italia/onto/ADMS/OWL"/>
        <dct:publisher rdf:resource="https://w3id.org/italia/data/public-organization/agd"/>
        <dcat:keyword xml:lang="it">Demanio</dcat:keyword>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/italia/real-estate/onto/StateProperty"/>
        <dct:description xml:lang="it">La risorsa modella il dominio dei beni immobili dello stato gestiti dall’Agenzia del Demanio, definendone le caratteristiche fisiche, le categorie patrimoniali e le specifiche destinazioni d&apos;uso. L&apos;ontologia permette di rappresentare i dati amministrativi e tecnici necessari alla gestione e al monitoraggio del patrimonio immobiliare dello Stato, facilitando l&apos;interoperabilità tra i sistemi informativi dell&apos;Agenzia del Demanio e delle altre pubbliche amministrazioni.</dct:description>
        <dct:creator rdf:resource="https://w3id.org/italia/data/public-organization/agd"/>
        <admsapit:status>catalogued</admsapit:status>
        <rdfs:comment xml:lang="en">Conceptual model for the representation of data related to state-owned real estate assets managed by the Italian State Property Agency, including aspects of cataloguing and usability certification.</rdfs:comment>
        <admsapit:semanticAssetInUse rdf:resource="https://w3id.org/italia/data/project/CLV"/>
        <dct:identifier>https://w3id.org/italia/real-estate/onto/StateProperty</dct:identifier>
        <dcat:keyword xml:lang="it">Beni immobili dello Stato</dcat:keyword>
        <prov:wasDerivedFrom rdf:resource="https://w3id.org/italia/real-estate/onto/StateProperty/1.0"/>
        <admsapit:hasSemanticAssetDistribution rdf:resource="https://w3id.org/italia/data/distribution/StateProperty-RDF-XML"/>
        <dcat:keyword xml:lang="en">Real estate</dcat:keyword>
        <admsapit:hasSemanticAssetDistribution rdf:resource="https://w3id.org/italia/data/distribution/StateProperty-RDF-TURTLE"/>
        <dct:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-16</dct:issued>
        <dct:subject rdf:resource="http://publications.europa.eu/resource/authority/data-theme/ECON"/>
        <dct:title xml:lang="it">Ontologia dei beni immobili dello Stato</dct:title>
        <dct:description xml:lang="en">The resource models the domain of state-owned real estate assets managed by the Italian State Property Agency, defining their physical characteristics, property categories, and specific uses. The ontology enables the representation of the administrative and technical data required for the management and monitoring of the State’s real estate assets, facilitating interoperability between the information systems of the State Property Agency and those of other public administrations.</dct:description>
        <rdfs:label xml:lang="en">State-Owned Real Estate Assets Ontology</rdfs:label>
        <admsapit:hasSemanticAssetDistribution rdf:resource="https://w3id.org/italia/data/distribution/StateProperty-JSON-LD"/>
        <dcat:theme rdf:resource="http://publications.europa.eu/resource/authority/data-theme/ECON"/>
        <dct:accrualPeriodicity rdf:resource="http://publications.europa.eu/resource/authority/frequency/IRREG"/>
        <dct:rightsHolder rdf:resource="https://w3id.org/italia/data/public-organization/agd"/>
        <admsapit:acronym>BIS</admsapit:acronym>
        <dct:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-16</dct:modified>
        <rdfs:label xml:lang="it">Ontologia dei beni immobili dello Stato</rdfs:label>
        <admsapit:hasKeyClass rdf:resource="https://w3id.org/italia/real-estate/onto/StateProperty/BeneImmobileDelloStato"/>
        <dct:creator rdf:resource="https://w3id.org/italia/data/public-organization/ISTAT"/>
        <owl:versionInfo xml:lang="en">Versione 1.0</owl:versionInfo>
        <admsapit:officialURI rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://w3id.org/italia/real-estate/onto/StateProperty</admsapit:officialURI>
        <admsapit:hasContributor rdf:resource="https://w3id.org/italia/data/organization/public-organization/td"/>
        <admsapit:prefix>StateProperty</admsapit:prefix>
        <dct:language rdf:resource="http://publications.europa.eu/resource/authority/language/ITA"/>
        <admsapit:status>published</admsapit:status>
        <dcat:contactPoint rdf:resource="https://w3id.org/italia/data/contact-point/ISTAT-NDC"/>
        <owl:versionInfo xml:lang="it">Version 1.0</owl:versionInfo>
    </owl:Ontology>
    


