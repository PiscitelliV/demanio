        <iri>
          <value>https://w3id.org/italia/real-estate/onto/StateProperty/haCategoriaPatrimoniale</value>
          <functional/>
          <annotations>
            <annotation>
              <subject>https://w3id.org/italia/real-estate/onto/StateProperty/haCategoriaPatrimoniale</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>ha categoria patrimoniale</lexicalForm>
                <datatype/>
                <language>it</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://w3id.org/italia/real-estate/onto/StateProperty/haCategoriaPatrimoniale</subject>
