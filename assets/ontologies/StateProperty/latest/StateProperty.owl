    </Annotation>
    <Annotation>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <Literal xml:lang="en">Conceptual model for the representation of data related to state-owned real estate assets managed by the Italian State Property Agency, including aspects of cataloguing and usability certification.</Literal>
    </Annotation>
    <Annotation>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <Literal xml:lang="it">Modello concettuale per la rappresentazione dei dati relativi ai beni immobili dello Stato gestiti dall’Agenzia del Demanio, inclusi gli aspetti di catalogazione e agibilità.</Literal>
    </Annotation>
