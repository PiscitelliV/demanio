<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoDiAccessoImmobile/BARR> a skos:Concept,
        :TipoDiAccessoImmobile ;
    skos:prefLabel "ACCESSO CON BARRIERE"@it,
        "BARRIER ACCESS"@en ;
    skos:definition "Immobile con presenza di barriere architettoniche che limitano o condizionano l'accessibilità."@it,
        "Property with architectural barriers that limit or condition accessibility."@en ;
    dct:identifier "BARR" ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/tipo-di-accesso> ;
    skos:notation "BARR" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoDiAccessoImmobile/COND> a skos:Concept,
        :TipoDiAccessoImmobile ;
    skos:prefLabel "ACCESSO CONDIZIONATO"@it,
        "CONDITIONAL ACCESS"@en ;
    skos:definition "Immobile accessibile solo in presenza di determinate condizioni temporali, eventi o circostanze specifiche."@it,
        "Property accessible only in the presence of certain temporal conditions, events or specific circumstances."@en ;
    dct:identifier "COND" ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/tipo-di-accesso> ;
    skos:notation "COND" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoDiAccessoImmobile/EMERG> a skos:Concept,
        :TipoDiAccessoImmobile ;
    skos:prefLabel "ACCESSO DI EMERGENZA"@it,
        "EMERGENCY ACCESS"@en ;
    skos:definition "Immobile con accesso consentito solo per motivi di emergenza, sicurezza o interventi urgenti."@it,
        "Property with access allowed only for emergency reasons, security or urgent interventions."@en ;
    dct:identifier "EMERG" ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/tipo-di-accesso> ;
    skos:notation "EMERG" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoDiAccessoImmobile/EVENTO> a skos:Concept,
        :TipoDiAccessoImmobile ;
    skos:prefLabel "ACCESSO PER EVENTI"@it,
        "EVENT ACCESS"@en ;
    skos:definition "Immobile accessibile solo in occasione di eventi, manifestazioni o iniziative specifiche."@it,
        "Property accessible only on the occasion of specific events, demonstrations or initiatives."@en ;
    dct:identifier "EVENTO" ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/tipo-di-accesso> ;
    skos:notation "EVENTO" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoDiAccessoImmobile/GUIDATO> a skos:Concept,
        :TipoDiAccessoImmobile ;
    skos:prefLabel "ACCESSO GUIDATO"@it,
        "GUIDED ACCESS"@en ;
    skos:definition "Immobile accessibile esclusivamente tramite visite guidate o accompagnamento di personale autorizzato."@it,
        "Property accessible exclusively through guided tours or accompaniment by authorized personnel."@en ;
    dct:identifier "GUIDATO" ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/tipo-di-accesso> ;
    skos:notation "GUIDATO" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoDiAccessoImmobile/ORARIO> a skos:Concept,
        :TipoDiAccessoImmobile ;
    skos:prefLabel "ACCESSO CON ORARIO"@it,
        "SCHEDULED ACCESS"@en ;
    skos:definition "Immobile accessibile solo in specifiche fasce orarie predeterminate e comunicate al pubblico."@it,
        "Property accessible only during specific predetermined time slots communicated to the public."@en ;
    dct:identifier "ORARIO" ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/tipo-di-accesso> ;
    skos:notation "ORARIO" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoDiAccessoImmobile/PRIV> a skos:Concept,
        :TipoDiAccessoImmobile ;
    skos:prefLabel "ACCESSO PRIVATO"@it,
        "PRIVATE ACCESS"@en ;
    skos:definition "Immobile a uso esclusivo, non accessibile al pubblico, riservato a specifici utenti o funzioni."@it,
        "Property for exclusive use, not accessible to the public, reserved for specific users or functions."@en ;
    dct:identifier "PRIV" ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/tipo-di-accesso> ;
    skos:notation "PRIV" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoDiAccessoImmobile/PUBB> a skos:Concept,
        :TipoDiAccessoImmobile ;
    skos:prefLabel "ACCESSO PUBBLICO"@it,
        "PUBLIC ACCESS"@en ;
    skos:definition "Immobile liberamente accessibile al pubblico senza necessità di autorizzazioni o limitazioni, nel rispetto degli orari e delle modalità stabilite."@it,
        "Property freely accessible to the public without the need for authorization or restrictions, in compliance with established schedules and procedures."@en ;
    dct:identifier "PUBB" ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/tipo-di-accesso> ;
    skos:notation "PUBB" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoDiAccessoImmobile/REGOL> a skos:Concept,
        :TipoDiAccessoImmobile ;
    skos:prefLabel "ACCESSO REGOLAMENTATO"@it,
        "REGULATED ACCESS"@en ;
    skos:definition "Immobile accessibile previo rispetto di specifiche condizioni, procedure o requisiti documentali (prenotazione, biglietto, registrazione)."@it,
        "Property accessible upon compliance with specific conditions, procedures or documentary requirements (booking, ticket, registration)."@en ;
    dct:identifier "REGOL" ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/tipo-di-accesso> ;
    skos:notation "REGOL" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoDiAccessoImmobile/RISV> a skos:Concept,
        :TipoDiAccessoImmobile ;
    skos:prefLabel "ACCESSO RISERVATO"@it,
        "RESTRICTED ACCESS"@en ;
    skos:definition "Immobile accessibile solo a personale autorizzato o a soggetti specificamente abilitati, con controlli all'ingresso."@it,
        "Property accessible only to authorized personnel or specifically qualified persons, with entry controls."@en ;
    dct:identifier "RISV" ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/tipo-di-accesso> ;
    skos:notation "RISV" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoDiAccessoImmobile/UNIV> a skos:Concept,
        :TipoDiAccessoImmobile ;
    skos:prefLabel "ACCESSO UNIVERSALE"@it,
        "UNIVERSAL ACCESS"@en ;
    skos:definition "Immobile progettato o adattato per garantire piena accessibilità a tutti, incluse persone con disabilità."@it,
        "Property designed or adapted to ensure full accessibility to all, including people with disabilities."@en ;
    dct:identifier "UNIV" ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/tipo-di-accesso> ;
    skos:notation "UNIV" .

